# MongoDB — local instance, no auth needed for dev
DB_CONNECTION_STRING=mongodb://localhost:27017/courselit

# Auth secret (randomly generated)
AUTH_SECRET=VrK9qEyi2Ju1Kpvr9lPLH+kKxumkjb0WnOaYTPw97G4=

# Super admin — CHANGE THIS to your actual email
SUPER_ADMIN_EMAIL=admin@example.com

# For sending emails (optional — without these, OTP codes print to the terminal)
# EMAIL_USER=email_user
# EMAIL_PASS=email_pass
# EMAIL_HOST=email_host
# EMAIL_FROM=email_from

# For storing files (optional — sign up at https://medialit.cloud for a key)
# MEDIALIT_APIKEY=medialit_apikey
# MEDIALIT_SERVER=https://api.medialit.cloud

# Queue server (optional — uncomment if running apps/queue)
# QUEUE_SERVER=http://localhost:4000

# SCORM cache directory
CACHE_DIR=/tmp
